{% extends "base.html.twig" %}

{% block body %}
	{{form_start(form, {'attr': {'class': 'container'}}) }}

	{{form_row(form.username)}}
	{{form_label(form.password)}}
	<div class="input-group mb-3">
		{{form_widget(form.password)}}
		<span role="button" class="input-group-text" onclick="togglePassword()">
			<i class="bi bi-eye" id="eye"></i>
			<i class="bi bi-eye-slash d-none" id="eye-slash"></i>
		</span>
	</div>
	{{form_errors(form.password)}}
	{{form_label(form.confirm)}}
	<div class="input-group mb-3">
		{{form_widget(form.confirm)}}
		<span role="button" class="input-group-text" onclick="togglePasswordConfirm()">
			<i class="bi bi-eye" id="eye"></i>
			<i class="bi bi-eye-slash d-none" id="eye-slash"></i>
		</span>
	</div>
	{{form_errors(form.confirm)}}
	<input class="btn btn-success mt-3" type="submit" value="Créer le compte">
	<div>
		<a href="/login" class="btn btn-link">Se connecter</a>
	</div>
{% endblock %}
