{% extends 'base.html.twig' %}

{% block body %}
	{% if error %}

		<div class="alert alert-danger mt-2">
			<p calss="mb-0">Les informations d'identifications sont invalides.</p>
		</div>
	{% endif %}

	<form class="container" method="post">
		<label for="username" class="form-label">Nom d'utilisateur</label>
		<input type="text" name="_username" id="username" value="{{last_username}}" class="form-control" required>
		<label for="password" class="form-label">Mot de passe</label>
		<div class="input-group">
			<input type="password" name="_password" id="user_password" class="form-control" required>
			<div class="input-group-append">
				<span role="button" class="input-group-text" onclick="togglePassword()">
					<i class="bi bi-eye" id="eye"></i>
					<i class="bi bi-eye-slash d-none" id="eye-slash"></i>
				</span>
			</div>
		</div>

		{# Redirect after a successfull connexion #}
		<input type="hidden" name="_target_path" value="/">
		<input type="submit" value="Connexion" class="btn btn-success mt-3">
	</form>
	<a href="/user/new" class="btn btn-link">Vous n'avez pas encore de compte ?</a>
{% endblock %}
